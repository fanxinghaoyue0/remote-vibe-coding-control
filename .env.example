# Cloudflare Worker runtime secrets
AGENT_TOKEN=replace-with-strong-random-token

# Local agent runtime
REMOTE_BASE_URL=https://your-worker-name.your-subdomain.workers.dev
AGENT_TOKEN=replace-with-same-token-as-worker
AGENT_ID=office-mac
MASTER_KEY=replace-with-your-master-password
CODEX_HOME=/Users/your-user/.codex
LOOP_INTERVAL_MS=2000
POLL_INTERVAL_ACTIVE_MS=3000
POLL_INTERVAL_IDLE_MS=5000
ACTIVITY_WINDOW_MS=120000
SNAPSHOT_DEBOUNCE_MS=1500
PRESENCE_PING_INTERVAL_MS=1800000
LIVE_SYNC_INTERVAL_MS=10000
REMOTE_RETRY_BASE_MS=15000
REMOTE_RETRY_MAX_MS=300000
REMOTE_QUOTA_COOLDOWN_MS=900000
